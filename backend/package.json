{
  "name": "ozono-backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "echo OZONO: dependencias instaladas, DB se inicializa al arrancar",
    "start": "node src/server.js",
    "render:start": "node scripts/start-production.mjs",
    "init-db": "node scripts/init-db.mjs",
    "dev": "node --watch src/server.js",
    "seed": "node scripts/seed.mjs",

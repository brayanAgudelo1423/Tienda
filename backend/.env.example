PORT=3001
NODE_ENV=development
JWT_SECRET=cambia-este-secreto-en-produccion
ADMIN_USER=admin
ADMIN_PASSWORD=ozono2026
FRONTEND_URL=http://localhost:5173

# PostgreSQL (obligatorio)
# Local con Docker: docker run -d --name ozono-pg -e POSTGRES_PASSWORD=ozono -e POSTGRES_DB=ozono -p 5432:5432 postgres:16
DATABASE_URL=postgresql://postgres:ozono@localhost:5432/ozono
PGSSL=false

# Mercado Pago (Colombia — recomendado)
# 1. Cuenta en https://www.mercadopago.com.co/developers
# 2. Tu integración → Credenciales → Access Token de prueba o producción
MERCADOPAGO_ACCESS_TOKEN=
# MERCADOPAGO_TEST=1

# PayU Latam (Colombia — opcional / respaldo)
PAYU_API_KEY=
PAYU_MERCHANT_ID=
PAYU_ACCOUNT_ID=512321
PAYU_TEST=1
BACKEND_URL=http://localhost:3001

# Catálogo: no ejecutar seed automático (producción con datos del admin)
# SKIP_SEED=1

# Imágenes del admin (Cloudinary — permanente en Render)
# Opción A — una sola variable (copia "API environment variable" del dashboard):
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Opción B — tres variables por separado:
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# CLOUDINARY_FOLDER=virtusmonaco

# Emails de pedidos
# ─────────────────────────────────────────────────────────────
# Render PLAN FREE bloquea Gmail SMTP (puertos 587/465). Usa Resend:
# 1. Crea cuenta en https://resend.com (gratis: 100 emails/día)
# 2. API Keys → Create API Key → copia en RESEND_API_KEY
# 3. Domains → añade virtusmonaco.store y configura DNS (recomendado)
#    O usa onboarding@resend.dev solo para pruebas iniciales
#
RESEND_API_KEY=
EMAIL_FROM=VirtusMonaco <pedidos@virtusmonaco.store>
ADMIN_NOTIFY_EMAIL=tu@correo.com
STORE_NAME=VirtusMonaco
#
# SMTP (solo desarrollo local — NO funciona en Render free):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# En Render (producción):
# DATABASE_URL se inyecta al vincular PostgreSQL al servicio web
# FRONTEND_URL=https://virtusmonaco.store
# BACKEND_URL=https://tienda-ur10.onrender.com
# Build Command: npm install && npm run build
# Start Command: npm run render:start

PORT=3001
NODE_ENV=development
JWT_SECRET=cambia-este-secreto-en-produccion
ADMIN_USER=admin
ADMIN_PASSWORD=ozono2026
FRONTEND_URL=http://localhost:5173

# PostgreSQL (obligatorio)
# Local con Docker: docker run -d --name ozono-pg -e POSTGRES_PASSWORD=ozono -e POSTGRES_DB=ozono -p 5432:5432 postgres:16
DATABASE_URL=postgresql://postgres:ozono@localhost:5432/ozono
PGSSL=false

# PayU Latam (Colombia)
PAYU_API_KEY=
PAYU_MERCHANT_ID=
PAYU_ACCOUNT_ID=512321
PAYU_TEST=1
BACKEND_URL=http://localhost:3001

# Catálogo: no ejecutar seed automático (producción con datos del admin)
# SKIP_SEED=1

# Emails de pedidos (opcional — Gmail, SendGrid, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=VirtusMonaco <no-reply@virtusmonaco.store>
# ADMIN_NOTIFY_EMAIL=tu@correo.com
# STORE_NAME=VirtusMonaco

# En Render (producción):
# DATABASE_URL se inyecta al vincular PostgreSQL al servicio web
# FRONTEND_URL=https://virtusmonaco.store
# BACKEND_URL=https://tienda-ur10.onrender.com
# Build Command: npm install && npm run build
# Start Command: npm run render:start

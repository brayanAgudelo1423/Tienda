# Frontend — copia a .env.local para desarrollo o .env.production para build
#
# Desarrollo local (recomendado): deja vacío y usa el proxy de Vite → localhost:3001
# VITE_API_URL=
#
# Desarrollo apuntando al backend local sin proxy:
# VITE_API_URL=http://localhost:3001
#
# Producción (GitHub Pages → Render):
VITE_API_URL=https://ozono.onrender.com
